FROM node:18-alpine AS build

WORKDIR /app

# 安装依赖（利用 Docker 层缓存）
COPY client/package.json client/package-lock.json* ./
RUN npm install

# 复制源码并构建
COPY client/ ./
RUN npm run build

# ---- 生产阶段 ----
FROM nginx:alpine

# 复制构建产物
COPY --from=build /app/dist /usr/share/nginx/html

# 复制 nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
